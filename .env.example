# API
PORT=4000
NODE_ENV=development

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database (add your DB URL here)
# DATABASE_URL=postgresql://user:password@localhost:5432/code_review_tool

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# GitHub OAuth App (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# Web origin (for CORS + redirect after login)
WEB_URL=http://localhost:3000

# Auth
JWT_SECRET=

# Gemini (free at aistudio.google.com/apikey)
GEMINI_API_KEY=

# GitHub Webhooks
WEBHOOK_SECRET=random-secret-here
WEBHOOK_URL=https://your-tunnel.ngrok.io
